          "id": "0DcW89UBjD4xU1q2",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst checklist = aiResponse.choices[0].message.content;\nconst hire = $('Google Sheets Trigger').first().json;\n\nreturn [{\n  json: {\n    name:        hire.Name,\n    email:       hire.Email,\n    role:        hire.Role,\n    department:  hire.Department,\n    start_date:  hire.StartDate,\n    manager:     hire.Manager,\n    checklist:   checklist,\n    employee_id: 'EMP-' + Date.now(),\n    onboarded_at: new Date().toISOString()\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
