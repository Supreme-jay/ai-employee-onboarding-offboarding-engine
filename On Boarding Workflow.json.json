      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Welcome to the team, {{ $json.name }}! Your onboarding guide inside",
        "message": "=<h2 style='color:#1a56db'>Welcome, {{ $json.name }}!</h2>\n<p>We're thrilled to have you join the <strong>{{ $json.department }}</strong> team\nas our new <strong>{{ $json.role }}</strong>.</p>\n<p>Your manager <strong>{{ $json.manager }}</strong> will reach out shortly.</p>\n<p>Your Employee ID: <strong>{{ $json.employee_id }}</strong></p>\n<h3>Your 30-Day Onboarding Plan</h3>\n<pre style='background:#f0f9ff;padding:16px;border-radius:8px;font-size:14px'>{{ $json.checklist }}</pre>\n<p style='color:#6b7280;font-size:13px'>Start date: {{ $json.start_date }}</p>\n<br><p>See you soon! 🎉</p>\n",
        "options": {}
      },
