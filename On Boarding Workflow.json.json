        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.7,\n  \"max_tokens\": 800,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert HR onboarding specialist. Generate a friendly, practical 30-day onboarding checklist for a new employee. Format as clean numbered sections: DAY 1 SETUP (items), WEEK 1 GOALS (items), WEEK 2-4 MILESTONES (items). Make it specific to their role and department. Keep it warm, encouraging, and actionable.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Create a 30-day onboarding plan for:\\nName: {{$json.Name}}\\nRole: {{$json.Role}}\\nDepartment: {{$json.Department}}\\nManager: {{$json.Manager}}\\nStart Date: {{ $json['Start Date'] }}\"\n    }\n  ]\n}\n",
        "options": {}
